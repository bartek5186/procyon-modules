{
  "schema_version": 1,
  "kind": "go-plugin",
  "name": "payment-system",
  "version": "0.2.0",
  "description": "Provider-based payments and subscriptions",
  "minimum_cli": "0.3.0",
  "minimum_core": "0.3.0",
  "go_module": "github.com/bartek5186/procyon-modules/payment-system",
  "package": "github.com/bartek5186/procyon-modules/payment-system",
  "factory": "New",
  "default_provider": "stripe",
  "providers": ["stripe", "google", "apple"],
  "environment": [
    {
      "name": "PAYMENT_ALLOWED_RETURN_ORIGINS",
      "default": "http://localhost,http://127.0.0.1",
      "description": "Comma-separated origins allowed for payment return URLs."
    },
    {
      "name": "STRIPE_SECRET_KEY",
      "description": "Stripe secret API key.",
      "providers": ["stripe"],
      "secret": true
    },
    {
      "name": "STRIPE_WEBHOOK_SECRET",
      "description": "Stripe webhook signing secret.",
      "providers": ["stripe"],
      "secret": true
    },
    {
      "name": "STRIPE_TRIAL_DAYS",
      "default": "0",
      "description": "Default Stripe subscription trial length in days.",
      "providers": ["stripe"]
    },
    {
      "name": "GOOGLE_PLAY_SERVICE_ACCOUNT_FILE",
      "description": "Path to the Google Play service account JSON file.",
      "providers": ["google"],
      "secret": true
    },
    {
      "name": "GOOGLE_PLAY_PACKAGE_NAME",
      "description": "Android application package name.",
      "providers": ["google"]
    },
    {
      "name": "APPLE_APP_STORE_CONFIG_FILE",
      "description": "Path to the Apple App Store verification config.",
      "providers": ["apple"],
      "secret": true
    }
  ]
}
